# Canyon Website Environment Variables
# Copy to .env.local and fill in values

# Anthropic API key for homepage demo (server-side only)
ANTHROPIC_API_KEY=sk-ant-...

# HubSpot tracking ID
NEXT_PUBLIC_HUBSPOT_ID=

# Calendly URL for "Book a Demo" buttons
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/canyon-demo

# Site URL (used for sitemap, OG tags)
NEXT_PUBLIC_SITE_URL=https://canyon.tech
